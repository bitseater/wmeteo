{
  "name": "wmeteo",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:exe": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.wmeteo.app",
    "productName": "WMeteo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "i18next": "^26.3.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "vite": "^8.1.0"
  },
  "overrides": {
    "fdir": "6.4.6"
  }
}
