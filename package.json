{
  "name": "wmeteo",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron": "npm run build && electron .",
    "dist:exe": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.wmeteo.app",
    "productName": "WMeteo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "i18next": "^26.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
